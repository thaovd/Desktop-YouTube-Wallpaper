<Window x:Class="DesktopVideoWallpaper.CalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cân chỉnh Vị trí Video" 
        Height="768" 
        Width="1024"
        WindowStyle="None" 
        ResizeMode="NoResize" 
        WindowState="Maximized"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Style for Resize Thumbs -->
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#4F46E5"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6366F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A35"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3F3F4F"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <!-- Semi-transparent overlay to emphasize the calibration box -->
        <Border Background="#22000000" IsHitTestVisible="False"/>

        <!-- Canvas containing the Draggable / Resizable Box -->
        <Canvas x:Name="CalibrationCanvas" Background="Transparent">
            <!-- The 3D/2D warp polygon -->
            <Polygon x:Name="SelectionPolygon" 
                     Stroke="#6366F1" 
                     StrokeThickness="2.5" 
                     Fill="#336366F1" 
                     Cursor="SizeAll"
                     MouseLeftButtonDown="SelectionPolygon_MouseLeftButtonDown"/>

            <!-- 4 corner handles -->
            <Thumb x:Name="ThumbP0" DragDelta="Thumb_DragDelta" Tag="0" Style="{StaticResource ResizeThumbStyle}" GotFocus="Thumb_GotFocus" LostFocus="Thumb_LostFocus"/>
            <Thumb x:Name="ThumbP1" DragDelta="Thumb_DragDelta" Tag="1" Style="{StaticResource ResizeThumbStyle}" GotFocus="Thumb_GotFocus" LostFocus="Thumb_LostFocus"/>
            <Thumb x:Name="ThumbP2" DragDelta="Thumb_DragDelta" Tag="2" Style="{StaticResource ResizeThumbStyle}" GotFocus="Thumb_GotFocus" LostFocus="Thumb_LostFocus"/>
            <Thumb x:Name="ThumbP3" DragDelta="Thumb_DragDelta" Tag="3" Style="{StaticResource ResizeThumbStyle}" GotFocus="Thumb_GotFocus" LostFocus="Thumb_LostFocus"/>
        </Canvas>

        <!-- Floating Instruction Card -->
        <Border CornerRadius="12" 
                Background="#1E1E2A" 
                BorderBrush="#4F46E5"
                BorderThickness="1.5"
                Padding="16" 
                Width="460" 
                Height="190"
                HorizontalAlignment="Center" 
                VerticalAlignment="Top" 
                Margin="0,30,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                    <TextBlock Text="CÂN CHỈNH VIDEO" 
                               Foreground="#FFFFFF" 
                               FontWeight="Bold" 
                               FontSize="14" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - " Foreground="#9CA3AF" FontSize="14" VerticalAlignment="Center"/>
                    <!-- Mode Selector -->
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                        <RadioButton x:Name="Radio2D" Content="Chế độ 2D (Chữ nhật)" IsChecked="True" Foreground="#FFFFFF" Margin="8,0" Checked="RadioMode_Checked"/>
                        <RadioButton x:Name="Radio3D" Content="Chế độ 3D (Góc chéo)" Foreground="#FFFFFF" Margin="8,0" Checked="RadioMode_Checked"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Row="1" 
                           Text="• Kéo thả vùng màu tím để di chuyển toàn bộ khung hình.&#x0a;• Kéo 4 chấm ở góc để chỉnh hình dáng (3D cho phép méo hình theo TV góc chéo).&#x0a;• Phím Mũi tên: Di chuyển khung hình hoặc điểm góc đang chọn." 
                           Foreground="#9CA3AF" 
                           FontSize="11.5" 
                           LineHeight="18"
                           TextWrapping="Wrap"/>

                <!-- Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Hủy bỏ" 
                            Style="{StaticResource CancelActionButton}" 
                            Width="90" 
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button Content="Lưu Vị Trí" 
                            Style="{StaticResource ActionButton}" 
                            Width="90"
                            Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
