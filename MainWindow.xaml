<Window x:Class="DesktopVideoWallpaper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="Desktop YouTube Wallpaper"
        Height="10" Width="10"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Normal"
        WindowStartupLocation="Manual"
        Left="0" Top="0"
        ShowInTaskbar="False"
        Topmost="False"
        Background="Black">
    
    <Grid Background="#0F0F1A">
        <!-- Modern, Premium Gradient Background for Loading State -->
        <Grid x:Name="LoadingPanel" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.8" RadiusY="0.8">
                    <GradientStop Color="#1A1A2E" Offset="0"/>
                    <GradientStop Color="#09090E" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Glowing Progress/Spinner Indicator -->
                <ProgressBar IsIndeterminate="True" 
                             Width="200" 
                             Height="6" 
                             Background="#2A2A40"
                             Foreground="#7F5AF0"
                             BorderThickness="0"
                             Margin="0,0,0,20"/>
                
                <TextBlock x:Name="TxtStatus" 
                           Text="Initializing Desktop Video Wallpaper..." 
                           Foreground="#E2E2E9" 
                           FontSize="20" 
                           FontWeight="Medium"
                           HorizontalAlignment="Center" 
                           TextAlignment="Center"
                           FontFamily="Segoe UI, Segoe UI Semibold, Arial"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Màn hình nền YouTube Live/Lofi đang tải..." 
                           Foreground="#94A1B2" 
                           FontSize="14" 
                           HorizontalAlignment="Center" 
                           TextAlignment="Center"
                           FontFamily="Segoe UI, Arial"
                           Margin="0"/>
            </StackPanel>
        </Grid>
        
        <!-- Microsoft WebView2 Control -->
        <wv2:WebView2 x:Name="MyWebView" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"
                      Visibility="Collapsed" />
                      



    </Grid>
</Window>
